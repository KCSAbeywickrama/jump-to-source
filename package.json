{
  "name": "jump-to-source",
  "displayName": "Jump to Source",
  "description": "Jump from a TypeScript declaration file to its source file.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:jump-to-source.jumpToSource"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jump-to-source.jumpToSource",
        "title": "Jump to Source"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "code-install": "npm run compile && npm run package && code --install-extension \"$npm_package_name-$npm_package_version.vsix\" --force"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.3"
  }
}
